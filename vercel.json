{
  "buildCommand": "cd catalog-app && npm install && npm run build",
  "outputDirectory": "catalog-app/dist",
  "rewrites": [
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/groopy-logo.png", "destination": "/groopy-logo.png" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
